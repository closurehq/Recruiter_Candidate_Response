# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Auth — any strong random string, e.g. openssl rand -hex 32
ADMIN_SECRET=

# Email (Resend — optional if using Gmail/Outlook MCP)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Cron — any strong random string, sent as Authorization: Bearer <value>
CRON_SECRET=

# Greenhouse webhook (optional — only needed if using the Greenhouse integration)
GREENHOUSE_WEBHOOK_SECRET=
